<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0055AA"
    tools:context=".NivelesActivity">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_boton_circular"
        android:padding="12dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_izq"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#333333" />
    <TextView
        android:id="@+id/tvTituloNiveles"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:fontFamily="@font/jersey_10"
        android:text="NIVELES"
        android:textColor="#FFCC00"
        android:textSize="50sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvTituloNiveles">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSumas"
            android:layout_width="220dp"
            android:layout_height="60dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/btn_pixel_art"
            android:fontFamily="@font/jersey_10"
            android:text="1. SUMA"
            android:textColor="#333333"
            android:textSize="32sp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnRestas"
            android:layout_width="220dp"
            android:layout_height="60dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/btn_pixel_art"
            android:fontFamily="@font/jersey_10"
            android:text="2. RESTA"
            android:textColor="#333333"
            android:textSize="32sp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnMult"
            android:layout_width="220dp"
            android:layout_height="60dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/btn_pixel_art"
            android:fontFamily="@font/jersey_10"
            android:text="3. MULTIPLICACIÓN"
            android:textColor="#333333"
            android:textSize="32sp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDiv"
            android:layout_width="220dp"
            android:layout_height="60dp"
            android:background="@drawable/btn_pixel_art"
            android:fontFamily="@font/jersey_10"
            android:text="4. DIVISIÓN"
            android:textColor="#333333"
            android:textSize="32sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>